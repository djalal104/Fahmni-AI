# ─────────────────────────────────────────────────────────────────────────────
# RAG PDF Chatbot - Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Use OpenAI directly OR OpenRouter (only one key should be set) ───────────

# Option A — OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option B — OpenRouter (OpenAI-compatible, many models): https://openrouter.ai/keys
# If OPENROUTER_API_KEY is set, it takes precedence over OPENAI_API_KEY.
OPENROUTER_API_KEY=

# ── LLM model ────────────────────────────────────────────────────────────────
# OpenAI examples: gpt-3.5-turbo | gpt-4o-mini | gpt-4o
# OpenRouter examples: openai/gpt-4o-mini | anthropic/claude-3-haiku
#
# Models ending in :free are shared across users and often return HTTP 429
# (rate limited upstream). If that happens: wait and retry, add OpenRouter
# credits and use a non-free model, or connect your own provider key in
# OpenRouter (Integrations). See: https://openrouter.ai/docs
#
LLM_MODEL=openai/gpt-4o-mini
